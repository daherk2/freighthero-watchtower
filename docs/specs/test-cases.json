    {
      "id": "3h_fresh_tracking_three_pings_in_geofence",
      "title": "Fresh tracking has 3 consecutive pings inside delivery geofence",
      "customer_id": "customer_b",
      "initial_state": "on_route_to_delivery",
      "events": [
        {
          "event_id": "evt-3h-1",
          "event_type": "tracking",
          "load_id": "load-visible-001",
          "customer_id": "customer_b",
          "occurred_at": "2026-05-11T17:30:00Z",
          "tracking": { "tracking_id": "trk-1", "lat": 32.777, "lng": -96.797, "distance_to_delivery_miles": 0.2, "ping_sequence": 1, "provider": "mock" }
        },
        {
          "event_id": "evt-3h-2",
          "event_type": "tracking",
          "load_id": "load-visible-001",
          "customer_id": "customer_b",
          "occurred_at": "2026-05-11T17:35:00Z",
          "tracking": { "tracking_id": "trk-2", "lat": 32.7769, "lng": -96.7971, "distance_to_delivery_miles": 0.1, "ping_sequence": 2, "provider": "mock" }
        },
        {
          "event_id": "evt-3h-3",
          "event_type": "tracking",
          "load_id": "load-visible-001",
          "customer_id": "customer_b",
          "occurred_at": "2026-05-11T17:40:00Z",
          "tracking": { "tracking_id": "trk-3", "lat": 32.7768, "lng": -96.7972, "distance_to_delivery_miles": 0.1, "ping_sequence": 3, "provider": "mock" }
        }
      ],
      "expected": {
        "required_tool_calls": [
          { "tool": "update_load_state", "arguments": { "target_state": "at_delivery" } },
          { "tool": "cancel_timers" }
        ],
        "forbidden_tool_calls": ["create_issue", "create_task", "update_eta"],
        "expected_state": "at_delivery"
      }
    },
