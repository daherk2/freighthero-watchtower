      "expected": {
        "required_tool_calls": [
          { "tool": "create_issue", "arguments": { "issue_type": "equipment_failure" } },
          { "tool": "send_sms", "contains": "review" }
        ],
        "forbidden_tool_calls": ["create_task", "update_eta", "update_load_state"],
