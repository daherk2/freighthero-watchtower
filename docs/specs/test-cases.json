  "cases": [
    {
      "id": "3b_load_question_found",
      "title": "Driver asks for delivery address and info is available",
      "customer_id": "customer_a",
      "initial_state": "on_route_to_delivery",
      "events": [
        {
          "event_id": "evt-3b",
          "event_type": "inbound_communication",
          "load_id": "load-visible-001",
          "customer_id": "customer_a",
          "occurred_at": "2026-05-11T17:05:00Z",
          "inbound_communication": {
            "channel": "sms",
            "sender_type": "driver",
            "sender_name": "Sam Driver",
            "content": "What's the delivery address?",
            "attachments": []
          }
        }
      ],
      "expected": {
        "required_tool_calls": [
          { "tool": "send_sms", "contains": "456 Delivery St" }
        ],
        "forbidden_tool_calls": ["create_task", "create_issue", "send_email", "forward_email", "send_slack_message"],
        "expected_state": "on_route_to_delivery"
      }
    },
    {
      "id": "3c_load_question_missing",
      "title": "Driver asks for missing load information",
      "customer_id": "customer_b",
      "initial_state": "on_route_to_delivery",
      "load_data_patch": {
        "stops[1].reference_numbers.receiver_phone": null
      },
      "events": [
        {
          "event_id": "evt-3c",
          "event_type": "inbound_communication",
          "load_id": "load-visible-001",
          "customer_id": "customer_b",
          "occurred_at": "2026-05-11T17:10:00Z",
          "inbound_communication": {
            "channel": "sms",
            "sender_type": "driver",
            "sender_name": "Sam Driver",
            "content": "Can you send receiver phone number?",
            "attachments": []
          }
        }
      ],
      "expected": {
        "required_tool_calls": [
          { "tool": "send_sms", "contains": "checking" },
          { "tool": "create_task", "arguments": { "task_type": "missing_load_info" } },
          { "tool": "send_slack_message", "arguments": { "audience": "broker" } }
        ],
        "forbidden_tool_calls": ["create_issue", "update_load_state"],
        "expected_state": "on_route_to_delivery"
      }
    },
    {
